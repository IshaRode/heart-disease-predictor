# =============================================================================
# Heart Disease Risk Predictor — Root .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment / secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example      # allow the template (no real secrets)

# ---------------------------------------------------------------------------
# Python / Backend
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.pkl           # trained model artifacts (regenerate via train.py)
*.joblib

# ---------------------------------------------------------------------------
# Node / Frontend
# ---------------------------------------------------------------------------
node_modules/
.next/
out/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# OS / Editor
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
.vercel
